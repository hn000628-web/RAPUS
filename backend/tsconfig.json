{
  "compilerOptions": {
    "module": "Node16",
    "moduleResolution": "node16",
    "target": "ES2022",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "sourceMap": true,
    "removeComments": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "strict": true,
    "strictNullChecks": true,
    "noImplicitAny": false,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "incremental": true,
    "tsBuildInfoFile": "./dist/.tsbuildinfo",

    /* ================================================== */
    /* SECTION 01 : PATH ALIAS */
    /* ================================================== */
    "paths": {
      "@/*": ["./*"],
      "@database/*": ["./database/*"],       // database alias 추가
      "@utils/*": ["./utils/*"],
      "@config/*": ["./config/*"],
      "@admin/*": ["./admin/*"],
      "@modules/*": ["./modules/*"]
    },

    /* ================================================== */
    "types": ["node", "express", "multer"]
  },

  "include": ["src"],
  "exclude": ["node_modules", "dist", "generated", "**/*.spec.ts"]
}